# Server Configuration
PORT=5000
NODE_ENV=development

# Database Connection (MongoDB)
# Replace with local MongoDB URI or MongoDB Atlas connection string
MONGODB_URI=mongodb://localhost:27017/campussphere

# JWT Authentication Secrets (Must be secure, long random strings in production)
# Access Token secret (short-lived)
JWT_SECRET=super_secure_jwt_access_token_secret_key_at_least_32_chars
# Refresh Token secret (long-lived)
JWT_REFRESH_SECRET=super_secure_jwt_refresh_token_secret_key_at_least_32_chars

# JWT Expirations (Optional, defaults apply if left blank)
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# Email Configuration (Nodemailer)
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=your_ethereal_user
SMTP_PASS=your_ethereal_pass
FROM_EMAIL=admissions@campussphere.edu
FROM_NAME=CampusSphere Admissions