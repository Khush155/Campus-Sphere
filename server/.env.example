# ============================================================
# CampusSphere Backend — Environment Configuration
# ============================================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# Validated at startup by: src/config/env.js (Zod schema)
# ============================================================

# ----------------------------------------------------------
# Server Configuration
# ----------------------------------------------------------

# Port the Express server listens on
# Used in: server.js, app.js (Swagger docs URL)
# Default: 5000
PORT=5000

# Application environment
# Used in: app.js (CORS), errorHandler.js (stack traces), logger.js (log level)
# Allowed values: development | production | test
# Default: development
NODE_ENV=development

# ----------------------------------------------------------
# Database (REQUIRED)
# ----------------------------------------------------------

# MongoDB connection string
# Used in: config/db.js → mongoose.connect()
# For local: mongodb://localhost:27017/campussphere
# For Atlas: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/campussphere
# REQUIRED — no default, server will NOT start without this
MONGODB_URI=mongodb://localhost:27017/campussphere

# ----------------------------------------------------------
# JWT Authentication (REQUIRED)
# ----------------------------------------------------------

# Secret key for signing short-lived access tokens
# Used in: middlewares/authMiddleware.js → jwt.verify()
# Must be at least 8 characters (use 32+ random chars in production)
# REQUIRED — no default, server will NOT start without this
JWT_SECRET=your_jwt_access_token_secret_here_min_8_chars

# Secret key for signing long-lived refresh tokens
# Used in: (reserved for future auth controller)
# Must be at least 8 characters (use 32+ random chars in production)
# REQUIRED — no default, server will NOT start without this
JWT_REFRESH_SECRET=your_jwt_refresh_token_secret_here_min_8_chars

# ----------------------------------------------------------
# JWT Token Expiry (Optional)
# ----------------------------------------------------------

# How long an access token stays valid before the client must refresh
# Used in: (reserved for future auth controller)
# Format: zeit/ms string (e.g., 15m, 1h, 2d)
# Default: 15m
ACCESS_TOKEN_EXPIRY=15m

# How long a refresh token stays valid
# Used in: (reserved for future auth controller)
# Format: zeit/ms string (e.g., 7d, 30d)
# Default: 7d
REFRESH_TOKEN_EXPIRY=7d
